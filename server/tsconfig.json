{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodeNext",
    "moduleResolution": "nodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": [
      "node",
      "jest"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@middleware/*": [
        "./src/middleware/*"
      ],
      "@errors/*": [
        "./src/errors/*"
      ],
      "@modules/*": [
        "./src/modules/*"
      ],
      "@db/*": [
        "./src/db/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}